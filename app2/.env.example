# Local development (copy to .env)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=rootroot
DB_NAME=librarydb
DB_PORT=3306
DB_SSL=false

# Railway: when you add a MySQL plugin and link it to this service,
# Railway injects MYSQLHOST, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE,
# MYSQLPORT, and MYSQL_URL automatically — no manual copy needed.

# Optional: restrict CORS when frontend is on another domain
# CLIENT_URL=https://libraryreact2-production.up.railway.app
